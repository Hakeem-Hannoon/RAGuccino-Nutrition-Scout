# Web app: local Expo Web can reach the API at localhost.
EXPO_PUBLIC_RAG_API_URL=http://localhost:8787

# Local RAG API
PORT=8787
RAG_FETCH_PAGES=true
RAG_MAX_WEB_RESULTS=5
RAG_MAX_FETCHED_PAGES=3

# OpenAI-compatible model endpoint.
# OpenAI example:
#   MODEL_BASE_URL=https://api.openai.com/v1
#   MODEL_API_KEY=sk-...
#   MODEL_NAME=gpt-4.1-mini
#
# Azure AI Foundry / Azure OpenAI example when exposed through an OpenAI-compatible route:
#   MODEL_BASE_URL=https://YOUR-RESOURCE.openai.azure.com/openai/v1
#   MODEL_API_KEY=...
#   MODEL_NAME=YOUR-DEPLOYMENT-NAME
#   MODEL_AUTH_HEADER=authorization
MODEL_BASE_URL=https://api.openai.com/v1
MODEL_API_KEY=
MODEL_NAME=gpt-4.1-mini
MODEL_AUTH_HEADER=authorization

# This app also accepts Spotter's Azure variable names directly:
# AZURE_FOUNDRY_ENDPOINT=
# AZURE_FOUNDRY_API_KEY=
# AZURE_FOUNDRY_MODEL=

# Web search provider. Tavily is the default recommendation for quick RAG demos.
# Set SEARCH_PROVIDER=tavily or SEARCH_PROVIDER=brave.
SEARCH_PROVIDER=tavily
TAVILY_API_KEY=
BRAVE_SEARCH_API_KEY=

# Optional nutrition-specific grounding.
# USDA FoodData Central gives structured nutrition facts; Open Food Facts can be
# reached through web search and does not require a key for basic product pages.
FDC_API_KEY=
